{
  "manifest_version": 3,
  "name": "Tenways Octo 0.7.2",
  "version": "0.7.2",
  "description": "跨平台协同助手 - Lark 到 Meegle 半自动建单工具",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://*.feishu.cn/*",
    "https://*.larksuite.com/*",
    "https://meegle.com/*",
    "https://*.meegle.com/*",
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background/router.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tenways Octo"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/api/lark/auth/callback*"
      ],
      "js": [
        "content-scripts/lark-auth-callback.js"
      ]
    },
    {
      "matches": [
        "https://*.feishu.cn/*",
        "https://*.larksuite.com/*"
      ],
      "exclude_matches": [
        "https://project.larksuite.com/*"
      ],
      "js": [
        "content-scripts/lark.js"
      ]
    },
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "content-scripts/github.js"
      ]
    },
    {
      "matches": [
        "https://meegle.com/*",
        "https://*.meegle.com/*",
        "https://project.larksuite.com/*"
      ],
      "js": [
        "content-scripts/meegle.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge/*"
      ],
      "matches": [
        "https://meegle.com/*",
        "https://*.meegle.com/*",
        "https://project.larksuite.com/*"
      ]
    },
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "https://*.feishu.cn/*",
        "https://*.larksuite.com/*",
        "https://meegle.com/*",
        "https://*.meegle.com/*",
        "https://github.com/*"
      ]
    },
    {
      "resources": [
        "sidebar-popup.html"
      ],
      "matches": [
        "https://*.feishu.cn/*",
        "https://*.larksuite.com/*",
        "https://meegle.com/*",
        "https://*.meegle.com/*",
        "https://github.com/*"
      ]
    }
  ]
}

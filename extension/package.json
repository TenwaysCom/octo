{
  "name": "tenways-octo-extension",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:manual": "WXT_CHROMIUM_PROFILE= wxt",
    "dev:profile": "sh ./scripts/dev-profile.sh",
    "build": "wxt build",
    "typecheck": "vue-tsc --noEmit",
    "clean": "wxt clean",
    "package": "wxt zip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "ant-design-vue": "^4.2.6",
    "vue": "^3.5.31",
    "webextension-polyfill": "^0.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.0.260",
    "@types/node": "^24.12.0",
    "@types/webextension-polyfill": "^0.10.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@wxt-dev/module-vue": "^1.0.3",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.6",
    "wxt": "^0.20.20"
  }
}

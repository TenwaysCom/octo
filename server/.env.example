# Lark App Configuration
# Get these from https://open.larksuite.com/app
LARK_APP_ID=cli_your_app_id
LARK_APP_SECRET=your_app_secret

# Server Configuration
PORT=3000
NODE_ENV=development
POSTGRES_URI=postgres://postgres:postgres@localhost:5432/tenways_octo

# Meegle Configuration
MEEGLE_BASE_URL=https://project.larksuite.com
MEEGLE_PLUGIN_ID=your_plugin_id
MEEGLE_PLUGIN_SECRET=your_plugin_secret
MEEGLE_PROJECT_KEY=4c3fv6

# Lark Base Workflow Defaults
LARK_BASE_DEFAULT_BASE_ID=XO0cbnxMIaralRsbBEolboEFgZc
LARK_BASE_DEFAULT_TABLE_ID=tblUfu71xwdul3NH

# Optional JSON config file for Lark Base → Meegle workflow mappings.
# If set and the file exists, it overrides LARK_BASE_ISSUE_TYPE_MAPPINGS.
# Each entry can include per-workitem-type fieldMappings.
# LARK_BASE_WORKFLOW_CONFIG_PATH=./config/lark-base-workflow.json

# Lark Base Issue Type → Meegle Workitem Mappings (JSON array)
# Supports one-to-many: multiple Lark labels can map to a single Meegle workitem type.
# urlSlug is the Meegle web UI path segment (api_name). Falls back to workitemTypeKey if omitted.
# Example: [{"larkLabels":["User Story","产品信息维护"],"workitemTypeKey":"story","templateId":"400329","urlSlug":"story"}]
LARK_BASE_ISSUE_TYPE_MAPPINGS='[
    {"larkLabels":["User Story","产品信息维护"],"workitemTypeKey":"story","templateId":"400329","urlSlug":"story"},
    {"larkLabels":["Tech Task"],"workitemTypeKey":"66700acbf297a8f821b4b860","templateId":"400152","urlSlug":"techtask"},
    {"larkLabels":["Production Bug"],"workitemTypeKey":"6932e40429d1cd8aac635c82","templateId":"645025","urlSlug":"production_bug"}
  ]'

# Fallback issue type when Lark Base "Issue 类型" is empty or unrecognized
LARK_BASE_DEFAULT_ISSUE_TYPE_FALLBACK=Bug

# Legacy fallback mappings (used when LARK_BASE_ISSUE_TYPE_MAPPINGS is empty)
LARK_BASE_ISSUE_TYPE_STORY=User Story
LARK_BASE_ISSUE_TYPE_TECH_TASK=Tech Task
LARK_BASE_ISSUE_TYPE_PROD_BUG=Production Bug

MEEGLE_WORKITEM_TYPE_KEY_STORY=story
MEEGLE_TEMPLATE_ID_STORY=400329
MEEGLE_WORKITEM_TYPE_KEY_TECH_TASK=
MEEGLE_TEMPLATE_ID_TECH_TASK=
MEEGLE_WORKITEM_TYPE_KEY_PROD_BUG=6932e40429d1cd8aac635c82
MEEGLE_TEMPLATE_ID_PROD_BUG=645025


[
  {
    "key": "github.lookup_pr",
    "title": "查询 PR 关联的 Meegle 工作项",
    "description": "从 GitHub PR 页面提取 Meegle ID 并查询工作项",
    "enabled": true,
    "priority": 10,
    "page_types": ["github"],
    "url_regexes": ["^https://github.com/.+/.+/pull/\\d+"],
    "allowed_roles": ["pm", "developer", "admin"],
    "executor_type": "action",
    "executor_config": {
      "actionKey": "lookup-github-pr"
    }
  },
  {
    "key": "meegle.update_lark_and_push",
    "title": "更新 Lark 及推送",
    "description": "更新当前 Meegle 工作项关联的 Lark 信息并推送通知",
    "enabled": true,
    "priority": 20,
    "page_types": ["meegle"],
    "url_regexes": ["^https?://.+/[^/]+/[^/]+/detail/[^/?#]+"],
    "allowed_roles": ["pm", "developer", "admin"],
    "executor_type": "action",
    "executor_config": {
      "actionKey": "update-lark-and-push"
    }
  },
  {
    "key": "meegle.create_github_branch",
    "title": "创建 GitHub 分支",
    "description": "基于当前 Meegle 工作项生成分支名并创建 GitHub 分支",
    "enabled": true,
    "priority": 30,
    "page_types": ["meegle"],
    "url_regexes": ["^https?://.+/[^/]+/[^/]+/detail/[^/?#]+"],
    "allowed_roles": ["pm", "developer", "admin"],
    "executor_type": "action",
    "executor_config": {
      "actionKey": "create-github-branch"
    }
  },
  {
    "key": "lark.bulk_create_meegle_tickets",
    "title": "批量创建 Meegle Ticket",
    "description": "在指定 Lark Base 视图中批量创建 Meegle ticket",
    "enabled": true,
    "priority": 40,
    "page_types": ["lark"],
    "url_regexes": ["^https?://.+/(base|bitable)/"],
    "allowed_roles": ["pm", "admin"],
    "executor_type": "action",
    "executor_config": {
      "actionKey": "bulk-create-meegle-tickets"
    }
  },
  {
    "key": "pm.analyze_current_page",
    "title": "分析当前页面",
    "description": "打开 Octo Chat，并把 PM 分析 prompt 填入输入框",
    "enabled": true,
    "priority": 50,
    "page_types": ["github", "lark", "meegle"],
    "url_regexes": ["^https?://"],
    "allowed_roles": ["pm", "requirement_owner", "admin"],
    "executor_type": "prompt",
    "executor_config": {
      "promptTemplate": "请基于当前页面做 PM 视角分析。页面类型：{{pageType}}，URL：{{url}}。请给出背景判断、风险点、下一步动作。"
    },
    "presentation_type": "open_chat"
  }
]

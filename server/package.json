{
  "name": "tenways-octo-server",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "db:migrate": "node dist/scripts/database-migrate.js",
    "db:reset": "node dist/scripts/database-migrate.js --reset",
    "db:import-sqlite": "node dist/scripts/database-import-sqlite.js",
    "start": "node dist/index.js",
    "dev": "concurrently -k -n tsc,server -c yellow,cyan \"npm:dev:watch\" \"npm:dev:serve\"",
    "dev:watch": "tsc --watch",
    "dev:serve": "nodemon --watch dist --ext js --delay 200ms dist/index.js",
    "kimi-acp:repl": "tsx ./examples/kimi-acp-client/repl.ts",
    "kimi-acp:validate": "tsx ./examples/kimi-acp-client/client.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.17.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "kysely": "^0.28.8",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.6",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "pg-mem": "^3.0.5",
    "tsx": "4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
